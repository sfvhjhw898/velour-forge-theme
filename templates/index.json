        "cell_3_stat_label": "Pieces per Collection",
        "cell_3_body": "A considered edit. Never more, never less.",
        "cell_4_heading": "Hand-Finished",
        "cell_4_body": "Every seam, every button, every hem. Finished by hand in our London studio.",
        "cell_5_heading": "Carbon Neutral",
