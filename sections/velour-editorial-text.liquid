{{ 'velour-brand.css' | asset_url | stylesheet_tag }}

<section class="velour-section vet-wrap" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; text-align: {{ section.settings.text_align }};">
  <div class="vet-inner v-fade-in">
    {%- if section.settings.eyebrow != blank -%}
      <p class="vet-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.statement != blank -%}
      <blockquote class="vet-statement">{{ section.settings.statement }}</blockquote>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a class="vet-cta" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>

<style>
.vet-wrap { background: var(--v-bg); }
.vet-inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  flex-direction: column;
  align-items: {% if section.settings.text_align == 'left' %}flex-start{% elsif section.settings.text_align == 'right' %}flex-end{% else %}center{% endif %};
  gap: 28px;
}
.vet-eyebrow {
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--v-muted);
  margin: 0;
}
.vet-statement {
  font-family: var(--v-font-heading);
  font-size: clamp(32px, 5.5vw, 68px);
  font-weight: 400;
  font-style: italic;
  line-height: 1.1;
  color: var(--v-text);
  margin: 0;
  max-width: 820px;
}
.vet-cta {
  display: inline-block;
  padding: 13px 32px;
  border: 1px solid var(--v-text);
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--v-text);
  background: transparent;
  transition: background var(--v-transition-fast), color var(--v-transition-fast);
}
.vet-cta:hover,
.vet-cta:focus-visible {
  background: var(--v-text);
  color: var(--v-bg);
}
.vet-cta:focus-visible { outline: 2px solid var(--v-text); outline-offset: 3px; }
@media (max-width: 600px) {
  .vet-inner { padding: 0 24px; }
  .vet-statement { font-size: clamp(26px, 8vw, 40px); }
}
</style>

<script>
(function(){
  var obs = new IntersectionObserver(function(e){
    e.forEach(function(i){ if(i.isIntersecting){ i.target.classList.add('is-visible'); obs.unobserve(i.target); }});
  },{ threshold: 0.15 });
  document.querySelectorAll('.vet-wrap .v-fade-in').forEach(function(el){ obs.observe(el); });
})();
</script>

{% schema %}
{
  "name": "VELOUR Editorial Text",
  "tag": "section",
  "class": "velour-section-editorial",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow label" },
    { "type": "textarea", "id": "statement",  "label": "Statement",  "default": "Crafted without compromise. Worn without apology." },
    { "type": "text",     "id": "cta_label",  "label": "Button label" },
    { "type": "url",      "id": "cta_url",    "label": "Button URL" },
    { "type": "select",   "id": "text_align", "label": "Alignment",
      "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}],
      "default": "center" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "VELOUR Editorial Text" }]
}
{% endschema %}
