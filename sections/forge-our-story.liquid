  flex-direction: column;
  justify-content: center;
}

.ps-strip__eyebrow {
  font-family: 'Inter', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(239, 237, 230, 0.4);
  margin: 0 0 1.6rem;
}

.ps-strip__body {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.2rem, 2.8vw, 3.4rem);
  font-weight: 400;
  line-height: 1.35;
  color: rgba(239, 237, 230, 0.9);
  margin: 0;
}

/* ── ⑦ VALUES GRID ── */
.ps-values {
  padding: 10rem 0;
  background: #efede6;
}

.ps-values__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.8rem, 4vw, 5.2rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  color: #37210b;
  margin: 0 0 6rem;
