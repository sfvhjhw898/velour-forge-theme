.ps-values__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 2.4rem;
  font-weight: 600;
  color: #37210b;
  margin: 0;
  letter-spacing: -0.01em;
}

.ps-values__body {
  font-family: 'Inter', sans-serif;
  font-size: 1.45rem;
  line-height: 1.65;
  color: rgba(55, 33, 11, 0.62);
  margin: 0;
}

/* ── ⑧ CLOSING CTA ── */
.ps-cta {
  padding: 10rem 0;
  background: #37210b;
}

.ps-cta__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4.8rem;
  text-align: center;
}

.ps-cta__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3.2rem, 5vw, 6.5rem);
  font-weight: 600;
  letter-spacing: -0.025em;
  color: #efede6;
  margin: 0;
  line-height: 1.1;
}

.ps-cta__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1.4rem;
  justify-content: center;
}

.ps-cta__btn {
  display: inline-flex;
  align-items: center;
  height: 5rem;
