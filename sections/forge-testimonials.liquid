{%- style -%}
  #shopify-section-{{ section.id }} .forge-testimonials {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .ftm-header {
    text-align: center;
    margin-bottom: 4.8rem;
  }

  #shopify-section-{{ section.id }} .ftm-eyebrow {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.4);
    display: block;
    margin-bottom: 1.2rem;
    font-family: var(--font-body-family, inherit);
  }

  #shopify-section-{{ section.id }} .ftm-heading {
    font-family: var(--forge-font-heading, Georgia, serif);
    font-size: clamp(2.4rem, 3vw, 3.6rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #shopify-section-{{ section.id }} .ftm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .ftm-grid {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }
  }

  #shopify-section-{{ section.id }} .ftm-card {
    border: 1px solid rgba(var(--color-foreground), 0.1);
    padding: 3.2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  #shopify-section-{{ section.id }} .ftm-stars {
    display: flex;
    gap: 0.3rem;
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .ftm-quote {
    font-family: var(--forge-font-heading, Georgia, serif);
    font-size: 1.75rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground));
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .ftm-author {
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    padding-top: 1.6rem;
  }

  #shopify-section-{{ section.id }} .ftm-author__name {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    font-family: var(--font-body-family, inherit);
  }

  #shopify-section-{{ section.id }} .ftm-author__role {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.45);
    margin-top: 0.3rem;
    font-family: var(--font-body-family, inherit);
  }
{%- endstyle -%}

<div class="forge-testimonials">
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="ftm-header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="ftm-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ftm-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ftm-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="ftm-card" {{ block.shopify_attributes }}>
            <div class="ftm-stars" aria-label="5 out of 5 stars">
              {%- for i in (1..5) -%}
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- if block.settings.quote != blank -%}
              <blockquote class="ftm-quote">"{{ block.settings.quote }}"</blockquote>
            {%- endif -%}

            <div class="ftm-author">
              {%- if block.settings.name != blank -%}
                <div class="ftm-author__name">{{ block.settings.name }}</div>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <div class="ftm-author__role">{{ block.settings.role }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Forge Testimonials",
  "tag": "section",
  "class": "forge-section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What our customers say"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "An exceptional product that exceeded every expectation."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "J. Smith"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Customer role or location",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Forge Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "The quality is absolutely outstanding. Worth every penny.",
            "name": "Sarah M.",
            "role": "Verified Buyer · London"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Fast delivery, beautiful packaging. I'll be ordering again.",
            "name": "Thomas R.",
            "role": "Verified Buyer · Manchester"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I was looking for something this good for years. Nothing else comes close.",
            "name": "Emily C.",
            "role": "Verified Buyer · Edinburgh"
          }
        }
      ]
    }
  ]
}
{% endschema %}
