{%- style -%}
  /* ── Forge Bento Grid — section {{ section.id }} ── */
  #shopify-section-{{ section.id }} .forge-bento {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .forge-bento__header {
    text-align: center;
    margin-bottom: 3.6rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__title {
    font-family: var(--forge-font-heading, Georgia, serif);
    font-size: clamp(2.4rem, 3.5vw, 4rem);
    font-weight: 600;
    color: rgb(var(--color-foreground));
    letter-spacing: -0.02em;
    margin: 0 0 0.8rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__subtitle {
    font-size: 1.6rem;
    color: rgba(var(--color-foreground-rgb, 0,0,0), 0.55);
    margin: 0;
    max-width: 52ch;
    margin-inline: auto;
  }

  /* ── Grid layout ── */
  #shopify-section-{{ section.id }} .forge-bento__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto auto;
    gap: 1.6rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell {
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    padding: 3.2rem 2.8rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 220px;
  }

  /* Tall left — spans 3 rows */
  #shopify-section-{{ section.id }} .forge-bento__cell--tall {
    grid-row: 1 / 4;
    min-height: 560px;
    justify-content: flex-end;
  }

  /* Wide bottom — spans cols 2–3 */
  #shopify-section-{{ section.id }} .forge-bento__cell--wide {
    grid-column: 2 / 4;
    min-height: 120px;
    justify-content: center;
  }

  /* Colour variants */
  #shopify-section-{{ section.id }} .forge-bento__cell--dark {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--dark-soft {
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.82);
    color: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--light {
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.04);
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--light-border {
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.02);
    border: 1.5px solid rgba(var(--color-foreground-rgb, 0,0,0), 0.08);
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--green-pale {
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.03);
    border: 1.5px solid rgba(var(--color-foreground-rgb, 0,0,0), 0.08);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--warm {
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.07);
  }

  /* ── Inner content ── */
  #shopify-section-{{ section.id }} .forge-bento__cell-inner {
    position: relative;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .forge-bento__eyebrow {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(var(--color-background-rgb, 255,255,255), 0.6);
    margin-bottom: 1.6rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell-heading {
    font-family: var(--forge-font-heading, Georgia, serif);
    font-size: clamp(2rem, 2.4vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1.4rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell-heading--sm {
    font-size: clamp(1.7rem, 1.9vw, 2.2rem);
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--dark .forge-bento__cell-heading,
  #shopify-section-{{ section.id }} .forge-bento__cell--dark-soft .forge-bento__cell-heading {
    color: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--light .forge-bento__cell-heading,
  #shopify-section-{{ section.id }} .forge-bento__cell--green-pale .forge-bento__cell-heading,
  #shopify-section-{{ section.id }} .forge-bento__cell--warm .forge-bento__cell-heading {
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .forge-bento__cell-body {
    font-size: 1.45rem;
    line-height: 1.65;
    margin: 0 0 1.6rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--dark .forge-bento__cell-body,
  #shopify-section-{{ section.id }} .forge-bento__cell--dark-soft .forge-bento__cell-body {
    color: rgba(var(--color-background-rgb, 255,255,255), 0.75);
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--light .forge-bento__cell-body,
  #shopify-section-{{ section.id }} .forge-bento__cell--green-pale .forge-bento__cell-body,
  #shopify-section-{{ section.id }} .forge-bento__cell--warm .forge-bento__cell-body {
    color: rgba(var(--color-foreground-rgb, 0,0,0), 0.6);
  }

  /* Link */
  #shopify-section-{{ section.id }} .forge-bento__link {
    display: inline-block;
    font-size: 1.35rem;
    font-weight: 500;
    color: rgba(var(--color-background-rgb, 255,255,255), 0.9);
    letter-spacing: 0.03em;
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--color-background-rgb, 255,255,255), 0.4);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  #shopify-section-{{ section.id }} .forge-bento__link:hover {
    color: rgb(var(--color-background));
    border-color: rgba(var(--color-background-rgb, 255,255,255), 0.9);
  }

  /* Icon */
  #shopify-section-{{ section.id }} .forge-bento__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(var(--color-foreground-rgb, 0,0,0), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.8rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__icon svg {
    stroke: rgb(var(--color-foreground));
  }

  /* Stat */
  #shopify-section-{{ section.id }} .forge-bento__cell-inner--stat {
    text-align: center;
    padding: 1rem 0;
  }

  #shopify-section-{{ section.id }} .forge-bento__stat {
    display: block;
    font-family: var(--forge-font-heading, Georgia, serif);
    font-size: clamp(4.8rem, 7vw, 8rem);
    font-weight: 600;
    color: rgb(var(--color-foreground));
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }

  #shopify-section-{{ section.id }} .forge-bento__stat-label {
    display: block;
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    margin-bottom: 1.2rem;
  }

  /* Dots background for stat card */
  #shopify-section-{{ section.id }} .forge-bento__dots-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: radial-gradient(circle, rgba(var(--color-foreground-rgb, 0,0,0), 0.12) 1.5px, transparent 1.5px);
    background-size: 20px 20px;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .forge-bento__cell--green-pale .forge-bento__cell-inner--stat {
    position: relative;
    z-index: 2;
  }

  /* Pill list (bottom wide cell) */
  #shopify-section-{{ section.id }} .forge-bento__cell-inner--pills {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .forge-bento__pill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem 2.4rem;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .forge-bento__pill-list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 1.4rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .forge-bento__pill-list svg {
    flex-shrink: 0;
    opacity: 0.7;
    stroke: rgb(var(--color-foreground));
  }

  /* Decorative element on tall card */
  #shopify-section-{{ section.id }} .forge-bento__cell-deco {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 200px;
    height: 200px;
    opacity: 0.06;
    pointer-events: none;
  }

  /* ── Scroll reveal ── */
  #shopify-section-{{ section.id }} .bento-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #shopify-section-{{ section.id }} .bento-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .forge-bento__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    #shopify-section-{{ section.id }} .forge-bento__cell--tall {
      grid-column: 1 / 3;
      grid-row: auto;
      min-height: 300px;
    }

    #shopify-section-{{ section.id }} .forge-bento__cell--wide {
      grid-column: 1 / 3;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .forge-bento__grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    #shopify-section-{{ section.id }} .forge-bento__cell--tall,
    #shopify-section-{{ section.id }} .forge-bento__cell--wide {
      grid-column: auto;
      grid-row: auto;
    }

    #shopify-section-{{ section.id }} .forge-bento__cell--tall {
      min-height: 340px;
    }

    #shopify-section-{{ section.id }} .forge-bento__cell {
      min-height: 180px;
      padding: 2.4rem 2rem;
    }

    #shopify-section-{{ section.id }} .forge-bento__cell--wide {
      min-height: 100px;
    }

    #shopify-section-{{ section.id }} .forge-bento__pill-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
{%- endstyle -%}

<div class="forge-bento" data-bento-reveal>
  <div class="page-width">

    <div class="forge-bento__header">
      <h2 class="forge-bento__title" data-reveal="masked">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="forge-bento__subtitle" data-reveal="slide-up" data-reveal-delay="200">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="forge-bento__grid">

      {%- comment -%} CELL 1: Tall left — brand story {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--tall forge-bento__cell--dark bento-reveal" data-delay="0">
        <div class="forge-bento__cell-inner">
          {%- if section.settings.cell_1_eyebrow != blank -%}
            <span class="forge-bento__eyebrow">{{ section.settings.cell_1_eyebrow }}</span>
          {%- endif -%}
          <h3 class="forge-bento__cell-heading">{{ section.settings.cell_1_heading }}</h3>
          <p class="forge-bento__cell-body">{{ section.settings.cell_1_body }}</p>
          {%- if section.settings.cell_1_cta != blank -%}
            <a href="{{ section.settings.story_link | default: '/pages/our-story' }}" class="forge-bento__link">{{ section.settings.cell_1_cta }}</a>
          {%- endif -%}
        </div>
        <div class="forge-bento__cell-deco" aria-hidden="true">
          {%- render 'icon-pattern-dots' -%}
        </div>
      </div>

      {%- comment -%} CELL 2: Top middle — quality/material {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--light bento-reveal" data-delay="80">
        <div class="forge-bento__cell-inner">
          <div class="forge-bento__icon" aria-hidden="true">
            {%- comment -%} Sparkle / star icon {%- endcomment -%}
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L13.5 8.5H20L14.5 12.5L16.5 19L12 15L7.5 19L9.5 12.5L4 8.5H10.5L12 2Z"/>
            </svg>
          </div>
          <h3 class="forge-bento__cell-heading forge-bento__cell-heading--sm">{{ section.settings.cell_2_heading }}</h3>
          <p class="forge-bento__cell-body">{{ section.settings.cell_2_body }}</p>
        </div>
      </div>

      {%- comment -%} CELL 3: Top right — stat {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--green-pale bento-reveal" data-delay="120">
        <div class="forge-bento__cell-inner forge-bento__cell-inner--stat">
          <span class="forge-bento__stat">{{ section.settings.cell_3_stat }}</span>
          <span class="forge-bento__stat-label">{{ section.settings.cell_3_stat_label }}</span>
          <p class="forge-bento__cell-body">{{ section.settings.cell_3_body }}</p>
        </div>
        <div class="forge-bento__dots-bg" aria-hidden="true"></div>
      </div>

      {%- comment -%} CELL 4: Middle middle — durability {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--warm bento-reveal" data-delay="160">
        <div class="forge-bento__cell-inner">
          <div class="forge-bento__icon" aria-hidden="true">
            {%- comment -%} Shield icon {%- endcomment -%}
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="forge-bento__cell-heading forge-bento__cell-heading--sm">{{ section.settings.cell_4_heading }}</h3>
          <p class="forge-bento__cell-body">{{ section.settings.cell_4_body }}</p>
        </div>
      </div>

      {%- comment -%} CELL 5: Middle right — craft/provenance {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--dark-soft bento-reveal" data-delay="200">
        <div class="forge-bento__cell-inner">
          <div class="forge-bento__icon" aria-hidden="true">
            {%- comment -%} Map pin / location icon {%- endcomment -%}
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3 class="forge-bento__cell-heading forge-bento__cell-heading--sm">{{ section.settings.cell_5_heading }}</h3>
          <p class="forge-bento__cell-body">{{ section.settings.cell_5_body }}</p>
        </div>
      </div>

      {%- comment -%} CELL 6: Bottom wide — pills {%- endcomment -%}
      <div class="forge-bento__cell forge-bento__cell--wide forge-bento__cell--light-border bento-reveal" data-delay="240">
        <div class="forge-bento__cell-inner forge-bento__cell-inner--pills">
          <ul class="forge-bento__pill-list">
            {%- if section.settings.pill_1 != blank -%}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {{ section.settings.pill_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.pill_2 != blank -%}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {{ section.settings.pill_2 }}
              </li>
            {%- endif -%}
            {%- if section.settings.pill_3 != blank -%}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {{ section.settings.pill_3 }}
              </li>
            {%- endif -%}
            {%- if section.settings.pill_4 != blank -%}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {{ section.settings.pill_4 }}
              </li>
            {%- endif -%}
          </ul>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function () {
  var section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section) return;
  var cells = section.querySelectorAll('.bento-reveal');
  if (!cells.length) return;

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        var delay = parseInt(el.getAttribute('data-delay') || '0', 10);
        setTimeout(function () {
          el.classList.add('is-visible');
        }, delay);
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.12 });

  cells.forEach(function (el) {
    observer.observe(el);
  });
})();
</script>

