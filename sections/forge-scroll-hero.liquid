{%- liquid
  assign heading = section.settings.heading | default: 'Made in England. Worn Everywhere.'
  assign heading_words = heading | split: ' '
  assign first_word = heading_words[0]
  assign rest_title = heading | remove_first: first_word | strip
-%}

<section class="forge-scroll-hero" id="forge-scroll-hero" data-section-id="{{ section.id }}">

  {{- '<!-- Background image - fades out as video expands -->' -}}
  <div class="psh-bg" id="psh-bg">
    {%- if section.settings.background_image -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        srcset="{{ section.settings.background_image | image_url: width: 750 }} 750w,
                {{ section.settings.background_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.background_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <div class="psh-bg__scrim"></div>
  </div>

  {{- '<!-- Stage: expanding media + overlaid title -->' -}}
  <div class="psh-stage">

    {{- '<!-- Expanding media container -->' -}}
    <div class="psh-media-wrap" id="psh-media-wrap">
      {%- if section.settings.video_url != blank -%}
        <video
          src="{{ section.settings.video_url }}"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          class="psh-media-el"
          disablepictureinpicture
        ></video>
      {%- elsif section.settings.image -%}
        <img
          src="{{ section.settings.image | image_url: width: 1920 }}"
          alt="{{ section.settings.image.alt | escape }}"
          class="psh-media-el"
          loading="eager"
        >
      {%- else -%}
        {{- 'lifestyle-1' | placeholder_svg_tag: 'psh-media-el psh-placeholder' -}}
      {%- endif -%}
      <div class="psh-media-overlay" id="psh-media-overlay"></div>
    </div>

    {{- '<!-- Split title text -->' -}}
    <div class="psh-titles" aria-label="{{ heading | escape }}">
      <span class="psh-title psh-title--left" id="psh-tl" aria-hidden="true">{{ first_word }}</span>
      <span class="psh-title psh-title--right" id="psh-tr" aria-hidden="true">{{ rest_title }}</span>
    </div>

    {{- '<!-- Scroll hint -->' -}}
    <div class="psh-hint" id="psh-hint">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      {{ section.settings.scroll_hint | default: 'Scroll to expand' }}
    </div>

  </div>

  {{- '<!-- Content revealed after full expansion -->' -}}
  <div class="psh-content" id="psh-content" aria-hidden="true">
    <div class="psh-content__inner page-width">
      {%- if section.settings.subheading != blank -%}
        <p class="psh-content__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="psh-content__btns">
        {%- if section.settings.button_label_1 != blank -%}
          <a href="{{ section.settings.button_link_1 }}" class="psh-btn psh-btn--primary">
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="psh-btn psh-btn--secondary">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

</section>

<style>
/* ── PITTCH Scroll Expansion Hero ── */
.forge-scroll-hero {
  position: relative;
  width: 100%;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #37210b;
  overflow: hidden;
}

/* Background image */
.psh-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.psh-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.psh-bg__scrim {
  position: absolute;
  inset: 0;
  background: rgba(55, 33, 11, 0.15);
}

/* Stage */
.psh-stage {
  position: relative;
  z-index: 10;
  width: 100%;
  height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Expanding media box */
.psh-media-wrap {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  height: 400px;
  max-width: 95vw;
  max-height: 85dvh;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 0 60px rgba(0, 0, 0, 0.4);
  /* JS drives width/height inline; no CSS transition = crisp JS control */
}

.psh-media-el {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.psh-placeholder {
  background: #5c3616;
}

.psh-media-overlay {
  position: absolute;
  inset: 0;
  background: rgba(55, 33, 11, 0.35);
  border-radius: 20px;
  pointer-events: none;
}

/* Split title */
.psh-titles {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.6rem;
  z-index: 20;
  pointer-events: none;
  white-space: nowrap;
}

.psh-title {
  display: inline-block;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3.6rem, 7vw, 8rem);
  font-weight: 600;
  color: #efede6;
  letter-spacing: -0.02em;
  line-height: 1;
  mix-blend-mode: difference;
  will-change: transform;
}

/* Scroll hint */
.psh-hint {
  position: absolute;
  bottom: 3.6rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: 'Inter', sans-serif;
  font-size: 1.2rem;
  font-weight: 500;
  color: rgba(239, 237, 230, 0.7);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  z-index: 20;
  pointer-events: none;
  animation: psh-bounce 2.2s ease-in-out infinite;
}

@keyframes psh-bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}

/* Revealed content below the expanded video */
.psh-content {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 6rem 0 5rem;
  background: #efede6;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.7s ease;
}

.psh-content.is-visible {
  opacity: 1;
  pointer-events: auto;
}

.psh-content__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3.2rem;
  text-align: center;
}

.psh-content__sub {
  font-family: 'Inter', sans-serif;
  font-size: clamp(1.6rem, 2vw, 2rem);
  color: rgba(55, 33, 11, 0.75);
  max-width: 52ch;
  margin: 0;
  line-height: 1.65;
}

.psh-content__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1.4rem;
  justify-content: center;
}

.psh-btn {
  display: inline-flex;
  align-items: center;
  height: 5rem;
  padding: 0 3.2rem;
  border-radius: 100px;
  font-family: 'Inter', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.psh-btn--primary {
  background: #37210b;
  color: #efede6;
  box-shadow: 0 4px 20px rgba(55, 33, 11, 0.25);
}

.psh-btn--primary:hover {
  background: #5c3616;
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(55, 33, 11, 0.3);
}

.psh-btn--secondary {
  background: transparent;
  color: #37210b;
  border: 1.5px solid rgba(55, 33, 11, 0.4);
}

.psh-btn--secondary:hover {
  border-color: #37210b;
  background: rgba(55, 33, 11, 0.06);
}

/* Fully expanded state */
.forge-scroll-hero.is-expanded .psh-media-wrap {
  border-radius: 0;
}

/* Responsive */
@media screen and (max-width: 749px) {
  .psh-titles {
    flex-direction: column;
    gap: 0.4rem;
  }
  .psh-title {
    font-size: clamp(3rem, 10vw, 5rem);
  }
}
</style>

<script>
/* ── PITTCH Page Intro — runs once per session on the homepage ── */
(function () {
  var isHome = window.location.pathname === '/' ||
               window.location.pathname === '';
  if (!isHome) return;
  if (sessionStorage.getItem('forge_intro_v1')) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  sessionStorage.setItem('forge_intro_v1', '1');
  window.__pittchIntroPlaying = true;

  var html = document.documentElement;
  html.classList.add('forge-intro-init');

  /* Double rAF: browser paints the hidden state before we trigger transitions */
  requestAnimationFrame(function () {
    requestAnimationFrame(function () {
      html.classList.add('forge-intro-play');

      /* Clean up after all transitions finish (~2 s longest + buffer) */
      setTimeout(function () {
        window.__pittchIntroPlaying = false;
        html.classList.remove('forge-intro-init', 'forge-intro-play');
      }, 2500);
    });
  });
})();
</script>

<script>
(function () {
  var hero     = document.getElementById('forge-scroll-hero');
  var bg       = document.getElementById('psh-bg');
  var mediaWrap = document.getElementById('psh-media-wrap');
  var mediaOverlay = document.getElementById('psh-media-overlay');
  var titleL   = document.getElementById('psh-tl');
  var titleR   = document.getElementById('psh-tr');
  var hint     = document.getElementById('psh-hint');
  var content  = document.getElementById('psh-content');

  if (!hero || !mediaWrap) return;

  var progress      = 0;
  var expanded      = false;
  var touchStartY   = 0;
  var raf           = null;
  var pendingDelta  = 0;

  /* ── Core update function ── */
  function applyProgress(p) {
    var mob  = window.innerWidth < 768;
    var maxW = window.innerWidth  * 0.97;
    var maxH = window.innerHeight * 0.92;
    var w    = Math.min(300 + p * (mob ? 680 : 1280), maxW);
    var h    = Math.min(400 + p * (mob ? 220 : 420), maxH);
    var tx   = p * (mob ? 140 : 150);
    var rad  = 20 * (1 - p);

    mediaWrap.style.width        = w + 'px';
    mediaWrap.style.height       = h + 'px';
    mediaWrap.style.borderRadius = rad + 'px';

    /* overlay fades as video fills */
    if (mediaOverlay) mediaOverlay.style.opacity = (0.35 - p * 0.35).toString();

    bg.style.opacity    = (1 - p).toString();

    titleL.style.transform = 'translateX(-' + tx + 'vw)';
    titleR.style.transform = 'translateX('  + tx + 'vw)';

    if (hint) hint.style.opacity = Math.max(0, 1 - p * 4).toString();
  }

  function onExpanded() {
    expanded = true;
    hero.classList.add('is-expanded');
    if (content) {
      content.classList.add('is-visible');
      content.removeAttribute('aria-hidden');
    }
    /* Re-enable native scroll */
    document.body.style.overflow = '';
  }

  function onCollapsed() {
    expanded = false;
    hero.classList.remove('is-expanded');
    if (content) {
      content.classList.remove('is-visible');
      content.setAttribute('aria-hidden', 'true');
    }
  }

  /* Prevent native scroll while hero is expanding */
  document.body.style.overflow = 'hidden';

  /* ── Wheel handler ── */
  function handleWheel(e) {
    if (window.__pittchIntroPlaying) { e.preventDefault(); return; }
    if (expanded) {
      /* If user scrolled back to top and wheels up → collapse */
      if (e.deltaY < 0 && window.scrollY <= 2) {
        e.preventDefault();
        expanded = false;
        onCollapsed();
        document.body.style.overflow = 'hidden';
      }
      return;
    }
    e.preventDefault();
    pendingDelta += e.deltaY * 0.0009;

    if (raf) return;
    raf = requestAnimationFrame(function () {
      raf = null;
      progress = Math.min(Math.max(progress + pendingDelta, 0), 1);
      pendingDelta = 0;
      applyProgress(progress);
      if (progress >= 1) {
        onExpanded();
        document.body.style.overflow = '';
      }
    });
  }

  /* ── Touch handlers ── */
  function handleTouchStart(e) {
    touchStartY = e.touches[0].clientY;
  }

  function handleTouchMove(e) {
    if (window.__pittchIntroPlaying) { e.preventDefault(); return; }
    if (!touchStartY) return;
    var deltaY = touchStartY - e.touches[0].clientY;

    if (expanded) {
      if (deltaY < -20 && window.scrollY <= 2) {
        e.preventDefault();
        expanded = false;
        onCollapsed();
        document.body.style.overflow = 'hidden';
      }
      return;
    }
    e.preventDefault();
    var factor = deltaY < 0 ? 0.007 : 0.005;
    progress = Math.min(Math.max(progress + deltaY * factor, 0), 1);
    applyProgress(progress);
    touchStartY = e.touches[0].clientY;
    if (progress >= 1) {
      onExpanded();
      document.body.style.overflow = '';
    }
  }

  function handleTouchEnd() { touchStartY = 0; }

  /* Prevent page scroll behind hero when not yet expanded */
  function handleScroll() {
    if (!expanded) window.scrollTo(0, 0);
  }

  /* ── Attach ── */
  window.addEventListener('wheel',      handleWheel,      { passive: false });
  window.addEventListener('touchstart', handleTouchStart, { passive: true });
  window.addEventListener('touchmove',  handleTouchMove,  { passive: false });
  window.addEventListener('touchend',   handleTouchEnd,   { passive: true });
  window.addEventListener('scroll',     handleScroll,     { passive: true });

  /* Initial render */
  applyProgress(0);
})();
</script>

{% schema %}
{
  "name": "Scroll Expansion Hero",
  "tag": "section",
  "class": "section section-scroll-hero",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Direct .mp4 URL. Upload via Files in Shopify Admin, then copy the URL."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (used if no video URL)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (fades out on scroll)"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made in England. Worn Everywhere.",
      "info": "First word slides left, rest slides right."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (shown after expansion)",
      "default": "Merino wool socks. Vibrant, sustainable, and crafted in Britain."
    },
    {
      "type": "text",
      "id": "scroll_hint",
      "label": "Scroll hint label",
      "default": "Scroll to expand"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "default": "Our Story →"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    }
  ],
  "presets": [
    {
      "name": "Scroll Expansion Hero"
    }
  ]
}
{% endschema %}
