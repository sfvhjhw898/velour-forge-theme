<style>
  @import url('https://fonts.googleapis.com/css2?family=Amatic+SC:wght@700&family=Cabin:wght@400;600&display=swap');
  .grd-ori { --grd-brown: #1A0F0A; --grd-cream: #F5EDD6; --grd-warm: #C4540E; --grd-paper: #EDE0C4; --grd-mid: #7A6152; --grd-border: #D4C4B0; background: var(--grd-brown); padding: {{ section.settings.padding_top }}px 64px {{ section.settings.padding_bottom }}px; font-family: 'Cabin', sans-serif; }
  .grd-ori__inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .grd-ori__eyebrow { display: block; font-size: 11px; letter-spacing: .24em; text-transform: uppercase; color: var(--grd-warm); margin: 0 0 20px; font-weight: 600; }
  .grd-ori__heading { font-family: 'Amatic SC', cursive; font-size: clamp(48px, 8vw, 96px); font-weight: 700; color: var(--grd-cream); margin: 0 0 24px; line-height: 1; }
  .grd-ori__body { font-size: 16px; line-height: 1.8; color: rgba(245,237,214,0.75); margin: 0 0 40px; font-weight: 400; }
  .grd-ori__stats { display: flex; gap: 40px; margin-bottom: 40px; }
  .grd-ori__stat-val { font-family: 'Amatic SC', cursive; font-size: 40px; font-weight: 700; color: var(--grd-warm); line-height: 1; display: block; }
  .grd-ori__stat-label { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: rgba(245,237,214,0.5); font-weight: 600; }
  .grd-ori__cta { display: inline-block; background: var(--grd-warm); color: var(--grd-cream); padding: 16px 48px; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; font-weight: 600; text-decoration: none; transition: background 0.3s ease; }
  .grd-ori__cta:hover { background: var(--grd-cream); color: var(--grd-brown); }
  .grd-ori__graphic { display: flex; align-items: center; justify-content: center; }
  .grd-ori__svg-wrap { width: 100%; max-width: 360px; opacity: 0.6; }
  @media (max-width: 900px) { .grd-ori { padding: 64px 24px; } .grd-ori__inner { grid-template-columns: 1fr; gap: 48px; } .grd-ori__graphic { display: none; } }
  @media (prefers-reduced-motion: reduce) { .grd-ori__cta { transition: none; } }
</style>

<section class="grd-ori">
  <div class="grd-ori__inner">
    <div class="grd-ori__text">
      {%- if section.settings.eyebrow != blank -%}<span class="grd-ori__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="grd-ori__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.body != blank -%}<p class="grd-ori__body">{{ section.settings.body }}</p>{%- endif -%}
      <div class="grd-ori__stats">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="grd-ori__stat"><span class="grd-ori__stat-val">{{ section.settings.stat_1_value }}</span><span class="grd-ori__stat-label">{{ section.settings.stat_1_label }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_2_value != blank -%}
          <div class="grd-ori__stat"><span class="grd-ori__stat-val">{{ section.settings.stat_2_value }}</span><span class="grd-ori__stat-label">{{ section.settings.stat_2_label }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_3_value != blank -%}
          <div class="grd-ori__stat"><span class="grd-ori__stat-val">{{ section.settings.stat_3_value }}</span><span class="grd-ori__stat-label">{{ section.settings.stat_3_label }}</span></div>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url | default: '/pages/sourcing' }}" class="grd-ori__cta">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>
    <div class="grd-ori__graphic" aria-hidden="true">
      <div class="grd-ori__svg-wrap">
        <svg viewBox="0 0 300 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M150 20 C80 60, 40 120, 50 200 C60 280, 100 340, 150 380 C200 340, 240 280, 250 200 C260 120, 220 60, 150 20z" stroke="#D4C4B0" stroke-width="1" fill="none"/>
          <path d="M150 60 C100 90, 70 140, 80 200 C90 260, 120 310, 150 340 C180 310, 210 260, 220 200 C230 140, 200 90, 150 60z" stroke="#D4C4B0" stroke-width="0.5" fill="none"/>
          <circle cx="150" cy="200" r="8" fill="#C4540E" opacity="0.8"/>
          <circle cx="110" cy="160" r="5" fill="#C4540E" opacity="0.5"/>
          <circle cx="190" cy="240" r="5" fill="#C4540E" opacity="0.5"/>
          <circle cx="130" cy="280" r="4" fill="#C4540E" opacity="0.4"/>
          <circle cx="170" cy="130" r="4" fill="#C4540E" opacity="0.4"/>
          <line x1="150" y1="200" x2="110" y2="160" stroke="#C4540E" stroke-width="0.5" opacity="0.4"/>
          <line x1="150" y1="200" x2="190" y2="240" stroke="#C4540E" stroke-width="0.5" opacity="0.4"/>
          <line x1="150" y1="200" x2="130" y2="280" stroke="#C4540E" stroke-width="0.5" opacity="0.4"/>
          <line x1="150" y1="200" x2="170" y2="130" stroke="#C4540E" stroke-width="0.5" opacity="0.4"/>
        </svg>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GROUNDS Origin",
  "tag": "section",
  "class": "grd-section-origin",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",        "default": "Where We Source" },
    { "type": "text",     "id": "heading",      "label": "Heading",        "default": "Beans worth knowing." },
    { "type": "textarea", "id": "body",         "label": "Body text",      "default": "Every coffee we roast is traceable to a single farm or cooperative." },
    { "type": "text",     "id": "stat_1_value", "label": "Stat 1 value",   "default": "24+" },
    { "type": "text",     "id": "stat_1_label", "label": "Stat 1 label",   "default": "Farms" },
    { "type": "text",     "id": "stat_2_value", "label": "Stat 2 value",   "default": "11" },
    { "type": "text",     "id": "stat_2_label", "label": "Stat 2 label",   "default": "Countries" },
    { "type": "text",     "id": "stat_3_value", "label": "Stat 3 value",   "default": "2016" },
    { "type": "text",     "id": "stat_3_label", "label": "Stat 3 label",   "default": "Since" },
    { "type": "text",     "id": "cta_label",    "label": "CTA label",      "default": "Our Sourcing Story" },
    { "type": "url",      "id": "cta_url",      "label": "CTA URL" },
    { "type": "range",    "id": "padding_top",    "label": "Padding top",    "min": 40, "max": 160, "step": 8, "default": 96 },
    { "type": "range",    "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 160, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "GROUNDS Origin" }]
}
{% endschema %}
