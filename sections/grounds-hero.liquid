<style>
  @import url('https://fonts.googleapis.com/css2?family=Amatic+SC:wght@700&family=Cabin:wght@400;600&display=swap');
  .grd-hero { --grd-brown: #1A0F0A; --grd-cream: #F5EDD6; --grd-warm: #C4540E; --grd-paper: #EDE0C4; --grd-mid: #7A6152; --grd-border: #D4C4B0; position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; font-family: 'Cabin', sans-serif; }
  .grd-hero__bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--grd-cream) 0%, var(--grd-paper) 100%); }
  .grd-hero__bg-img { position: absolute; inset: 0; object-fit: cover; width: 100%; height: 100%; display: block; }
  .grd-hero__overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(26,15,10,0.2) 0%, rgba(26,15,10,0.65) 100%); }
  .grd-hero__inner { position: relative; z-index: 2; text-align: center; max-width: 800px; padding: 80px 40px; }
  .grd-hero__eyebrow { display: block; font-size: 11px; letter-spacing: .28em; text-transform: uppercase; color: var(--grd-warm); margin: 0 0 24px; font-weight: 600; }
  .grd-hero__heading { font-family: 'Amatic SC', cursive; font-size: clamp(64px, 14vw, 140px); font-weight: 700; line-height: 0.9; color: var(--grd-cream); margin: 0 0 28px; }
  .grd-hero__sub { font-size: 16px; line-height: 1.75; color: rgba(245,237,214,0.85); max-width: 520px; margin: 0 auto 48px; font-weight: 400; }
  .grd-hero__btn { display: inline-block; background: var(--grd-cream); color: var(--grd-brown); padding: 18px 56px; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; font-weight: 600; text-decoration: none; transition: background 0.3s ease, color 0.3s ease; }
  .grd-hero__btn:hover { background: var(--grd-warm); color: var(--grd-cream); }
  @media (max-width: 640px) { .grd-hero__inner { padding: 80px 24px; } }
  @media (prefers-reduced-motion: reduce) { .grd-hero__btn { transition: none; } }
</style>

<section class="grd-hero">
  <div class="grd-hero__bg"></div>
  {%- if section.settings.image != blank -%}
    <img class="grd-hero__bg-img" src="{{ section.settings.image | image_url: width: 1800 }}" alt="" loading="eager" width="1800" height="1200">
    <div class="grd-hero__overlay"></div>
  {%- endif -%}
  <div class="grd-hero__inner">
    {%- if section.settings.eyebrow != blank -%}<span class="grd-hero__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h1 class="grd-hero__heading">{{ section.settings.heading | default: 'Great Coffee.' }}</h1>
    {%- if section.settings.subheading != blank -%}<p class="grd-hero__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url | default: '/collections/all' }}" class="grd-hero__btn">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "GROUNDS Hero",
  "tag": "section",
  "class": "grd-section-hero",
  "settings": [
    { "type": "text",         "id": "eyebrow",    "label": "Eyebrow",    "default": "From Origin to Cup" },
    { "type": "text",         "id": "heading",    "label": "Heading",    "default": "Great Coffee." },
    { "type": "textarea",     "id": "subheading", "label": "Subheading", "default": "Specialty single-origin beans, roasted to order in our London workshop." },
    { "type": "image_picker", "id": "image",      "label": "Background image" },
    { "type": "text",         "id": "btn_label",  "label": "Button label", "default": "Shop Coffee" },
    { "type": "url",          "id": "btn_url",    "label": "Button URL" }
  ],
  "presets": [{ "name": "GROUNDS Hero" }]
}
{% endschema %}
