<section class="forge-editorial-cta color-{{ section.settings.color_scheme }}"
         style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;{%- if section.settings.bg_image != blank -%}position:relative;overflow:hidden;{%- endif -%}">
  {%- if section.settings.bg_image != blank -%}
    <div class="forge-editorial-cta__overlay" style="position:absolute;inset:0;background:rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});z-index:1;pointer-events:none"></div>
    {{- section.settings.bg_image | image_url: width: 1600 | image_tag:
      loading: 'lazy',
      class: 'forge-editorial-cta__bg',
      style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0',
      widths: '750,1100,1600',
      sizes: '100vw'
    -}}
  {%- endif -%}
  <div class="forge-editorial-cta__inner" style="position:relative;z-index:2">
    {%- if section.settings.eyebrow != blank -%}
      <p class="forge-editorial-cta__eyebrow" data-forge-anim="fade-up">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="forge-editorial-cta__heading"
        data-forge-split="words"
        data-forge-split-anim="slide">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}
      <p class="forge-editorial-cta__sub" data-forge-anim="fade-up">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="forge-editorial-cta__buttons">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url }}" class="button button--primary" data-forge-magnet="0.3">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_url_2 }}" class="button button--secondary" data-forge-magnet="0.3">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FORGE Editorial CTA",
  "tag": "section",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow text"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Discover the collection"},
    {"type": "textarea", "id": "subtext", "label": "Subtext", "default": "Handcrafted pieces that tell a story."},
    {"type": "text", "id": "button_label", "label": "Button 1 label", "default": "Shop now"},
    {"type": "url", "id": "button_url", "label": "Button 1 URL"},
    {"type": "text", "id": "button_label_2", "label": "Button 2 label (optional)"},
    {"type": "url", "id": "button_url_2", "label": "Button 2 URL"},
    {"type": "image_picker", "id": "bg_image", "label": "Background image (optional)"},
    {"type": "range", "id": "overlay_opacity", "label": "Image overlay opacity", "min": 0, "max": 80, "step": 5, "default": 40, "unit": "%"},
    {"type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-5"},
    {"type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 200, "step": 8, "default": 120, "unit": "px"},
    {"type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 200, "step": 8, "default": 120, "unit": "px"}
  ],
  "blocks": [{"type": "@app"}],
  "presets": [{"name": "FORGE Editorial CTA"}]
}
{% endschema %}
