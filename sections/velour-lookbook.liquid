{{ 'velour-brand.css' | asset_url | stylesheet_tag }}

<section class="velour-section vlb-wrap" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">

  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="vlb-header v-fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <p class="vlb-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vlb-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="vlb-track v-stagger">
    {%- for block in section.blocks -%}
      <article class="vlb-card v-fade-in" {{ block.shopify_attributes }}>
        <a class="vlb-card__link" href="{{ block.settings.link_url | default: '#' }}" aria-label="{{ block.settings.caption | default: 'View look' | escape }}">
          <div class="vlb-card__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 768px) 80vw, 340px"
                alt="{{ block.settings.image.alt | default: block.settings.caption | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="400" height="600"
                class="vlb-card__img">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'vlb-card__img vlb-card__img--placeholder' }}
            {%- endif -%}
            <div class="vlb-card__caption v-glass">
              {%- if block.settings.caption != blank -%}
                <p class="vlb-card__caption-text">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <span class="vlb-card__cta">{{ block.settings.link_label }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      </article>
    {%- else -%}
      <p class="vlb-empty">Add looks using the block editor.</p>
    {%- endfor -%}
  </div>

</section>

<style>
.vlb-wrap { background: var(--v-bg); overflow: hidden; }

.vlb-header {
  max-width: 640px;
  margin: 0 auto 48px;
  text-align: center;
  padding: 0 24px;
}
.vlb-eyebrow {
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--v-muted);
  margin: 0 0 14px;
}
.vlb-heading {
  font-family: var(--v-font-heading);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  font-style: italic;
  color: var(--v-text);
  margin: 0;
}

.vlb-track {
  display: flex;
  gap: 2px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding: 0 40px 32px;
  scrollbar-width: none;
}
.vlb-track::-webkit-scrollbar { display: none; }

.vlb-card {
  flex: 0 0 clamp(260px, 28vw, 380px);
  scroll-snap-align: start;
}
.vlb-card__link {
  display: block;
  text-decoration: none;
}
.vlb-card__img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 2 / 3;
  background: var(--v-border);
}
.vlb-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform var(--v-transition);
}
.vlb-card__img--placeholder { opacity: .35; }
.vlb-card__link:hover .vlb-card__img,
.vlb-card__link:focus-visible .vlb-card__img {
  transform: scale(1.04);
}

.vlb-card__caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px 18px 16px;
  transform: translateY(6px);
  transition: transform var(--v-transition);
}
.vlb-card__link:hover .vlb-card__caption,
.vlb-card__link:focus-visible .vlb-card__caption {
  transform: translateY(0);
}
.vlb-card__caption-text {
  font-family: var(--v-font-heading);
  font-style: italic;
  font-size: 15px;
  color: var(--v-text);
  margin: 0 0 6px;
  line-height: 1.3;
}
.vlb-card__cta {
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--v-secondary);
}

.vlb-empty {
  padding: 40px;
  color: var(--v-muted);
  font-size: 14px;
}

.vlb-card__link:focus-visible {
  outline: 2px solid var(--v-text);
  outline-offset: 3px;
}

@media (prefers-reduced-motion: reduce) {
  .vlb-card__img,
  .vlb-card__caption { transition: none; transform: none !important; }
}

@media (max-width: 600px) {
  .vlb-track { padding: 0 16px 24px; gap: 10px; }
  .vlb-card { flex: 0 0 72vw; }
}
</style>

<script>
(function(){
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('is-visible'); obs.unobserve(e.target); }});
  }, { threshold: 0.12 });
  document.querySelectorAll('.vlb-wrap .v-fade-in').forEach(function(el){ obs.observe(el); });
})();
</script>

{% schema %}
{
  "name": "VELOUR Lookbook",
  "tag": "section",
  "class": "velour-section-lookbook",
  "settings": [
    { "type": "text",    "id": "eyebrow",      "label": "Eyebrow",    "default": "The Collection" },
    { "type": "text",    "id": "heading",       "label": "Heading",    "default": "The Edit" },
    { "type": "select",  "id": "color_scheme",  "label": "Color scheme", "options": [{"value":"scheme-1","label":"Scheme 1"},{"value":"scheme-2","label":"Scheme 2"}], "default": "scheme-1" },
    { "type": "range",   "id": "padding_top",   "label": "Padding top",    "min": 0, "max": 120, "step": 8, "default": 80 },
    { "type": "range",   "id": "padding_bottom","label": "Padding bottom", "min": 0, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        { "type": "image_picker", "id": "image",       "label": "Image" },
        { "type": "text",         "id": "caption",     "label": "Caption",    "default": "New Season" },
        { "type": "text",         "id": "link_label",  "label": "Link label", "default": "Shop Now" },
        { "type": "url",          "id": "link_url",    "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "VELOUR Lookbook",
      "blocks": [
        { "type": "look", "settings": { "caption": "New Season",    "link_label": "Explore" } },
        { "type": "look", "settings": { "caption": "Outerwear",     "link_label": "Shop"    } },
        { "type": "look", "settings": { "caption": "The Wardrobe",  "link_label": "View"    } }
      ]
    }
  ]
}
{% endschema %}
