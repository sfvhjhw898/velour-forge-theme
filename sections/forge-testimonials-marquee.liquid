{%- assign speed = section.settings.speed | default: 60 -%}
<section class="forge-testimonials-marquee color-{{ section.settings.color_scheme }}"
         style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;overflow:hidden">
  {%- if section.settings.heading != blank -%}
    <div class="page-width" style="margin-bottom:2rem">
      <h2 style="font-family:var(--forge-font-heading,serif);font-size:clamp(1.6rem,3vw,3rem);font-weight:700;letter-spacing:-.02em" data-forge-anim="fade-up">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}
  <div class="forge-testimonials-marquee__row" data-forge-ticker-wrap>
    <div class="forge-testimonials-marquee__track" data-forge-ticker data-forge-ticker-speed="{{ speed }}" data-forge-ticker-dir="{{ section.settings.direction }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="forge-testimonials-marquee__card" {{ block.shopify_attributes }}>
            <div class="forge-testimonials-marquee__stars">
              {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
            </div>
            <p class="forge-testimonials-marquee__quote">"{{ block.settings.quote }}"</p>
            <p class="forge-testimonials-marquee__author">— {{ block.settings.author }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FORGE Testimonials Marquee",
  "tag": "section",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "What people say"},
    {"type": "range", "id": "speed", "label": "Speed", "min": 20, "max": 120, "step": 10, "default": 60},
    {"type": "select", "id": "direction", "label": "Direction", "options": [{"value": "ltr", "label": "Left"}, {"value": "rtl", "label": "Right"}], "default": "ltr"},
    {"type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1"},
    {"type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 8, "default": 64, "unit": "px"},
    {"type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 8, "default": 64, "unit": "px"}
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {"type": "text", "id": "quote", "label": "Quote", "default": "Absolutely transformed my wardrobe."},
        {"type": "text", "id": "author", "label": "Author", "default": "Sarah M."},
        {"type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5}
      ]
    },
    {"type": "@app"}
  ],
  "presets": [
    {
      "name": "FORGE Testimonials Marquee",
      "blocks": [
        {"type": "testimonial", "settings": {"quote": "Exceptional quality and fast delivery.", "author": "James L.", "rating": 5}},
        {"type": "testimonial", "settings": {"quote": "My go-to brand now. Nothing else compares.", "author": "Priya K.", "rating": 5}},
        {"type": "testimonial", "settings": {"quote": "Stunning product, beautifully packaged.", "author": "Tom R.", "rating": 5}},
        {"type": "testimonial", "settings": {"quote": "Worth every penny. Will order again.", "author": "Emily C.", "rating": 5}}
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
