{%- comment -%}
  sections/forge-collection-showcase.liquid
  FORGE Pittch-standard stacked collection cards section.
  Wraps snippets/forge-stacked-cards.liquid.

  Colours are set via section settings so they're overrideable in the theme editor.
{%- endcomment -%}

{%- assign forge_stacks_heading = section.settings.heading -%}
{%- assign forge_stacks_sub     = section.settings.subheading -%}
{%- assign forge_stacks_bg      = section.settings.background_color -%}
{%- assign forge_stacks_text    = section.settings.text_color -%}
{%- assign forge_stacks_accent  = section.settings.accent_color -%}

{%- render 'forge-stacked-cards' -%}

{% schema %}
{
  "name": "FORGE Collection Showcase",
  "tag": "section",
  "class": "section forge-collection-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Range"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "collection_stack",
      "name": "Collection Stack",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stack label",
          "default": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FORGE Collection Showcase",
      "blocks": [
        { "type": "collection_stack", "settings": { "label": "New Arrivals" } },
        { "type": "collection_stack", "settings": { "label": "Best Sellers" } },
        { "type": "collection_stack", "settings": { "label": "Sale" } }
      ]
    }
  ]
}
{% endschema %}
