<style>
  .forge-editorial-hero {
    height: 100vh;
    min-height: 600px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
  }

  .forge-editorial-hero__left {
    background: #1A1A1A;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .forge-editorial-hero__metadata {
    width: 100%;
    height: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.3);
  }

  .forge-editorial-hero__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 60px;
  }

  .forge-editorial-hero__heading {
    overflow: hidden;
  }

  .forge-editorial-hero__heading-line {
    font-family: var(--forge-font-heading);
    font-size: clamp(5rem, 8vw, 9rem);
    color: white;
    letter-spacing: -0.03em;
    line-height: 0.92;
    animation: forge-clip-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    clip-path: inset(0 100% 0 0);
  }

  .forge-editorial-hero__heading-line:first-child {
    font-weight: 300;
    font-style: italic;
    animation-delay: 0s;
  }

  .forge-editorial-hero__heading-line:last-child {
    font-weight: 600;
    animation-delay: 0.15s;
  }

  @keyframes forge-clip-reveal {
    from {
      clip-path: inset(0 100% 0 0);
    }
    to {
      clip-path: inset(0 0% 0 0);
    }
  }

  .forge-editorial-hero__subheading {
    margin-top: 1.8rem;
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
  }

  .forge-editorial-hero__cta {
    margin-top: 3.2rem;
  }

  .forge-editorial-hero__button {
    display: inline-block;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-radius: 100px;
    padding: 14px 32px;
    color: white;
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .forge-editorial-hero__button:hover {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
  }

  .forge-editorial-hero__accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: #C4A882;
    opacity: 0.4;
  }

  .forge-editorial-hero__right {
    overflow: hidden;
    position: relative;
  }

  .forge-editorial-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .forge-editorial-hero__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2A1A10 0%, #1A1A1A 50%, #0D0D0D 100%);
  }

  .forge-editorial-hero__right::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.35) 100%);
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .forge-editorial-hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto 65vw;
      height: auto;
      min-height: 0;
    }

    .forge-editorial-hero__right {
      order: -1;
    }

    .forge-editorial-hero__metadata {
      padding: 0 24px;
    }

    .forge-editorial-hero__content {
      padding: 60px 24px;
    }

    .forge-editorial-hero__heading-line {
      font-size: clamp(3rem, 12vw, 5rem);
    }
  }
</style>

<div class="forge-editorial-hero">
  <div class="forge-editorial-hero__left">
    <div class="forge-editorial-hero__metadata">
      <span>EST. 2024</span>
      <span>London, UK</span>
    </div>

    <div class="forge-editorial-hero__content">
      <div class="forge-editorial-hero__heading">
        {%- assign heading_parts = section.settings.heading | default: "Dressed. With Intent." | split: ". " -%}
        {%- for part in heading_parts -%}
          {%- if part != blank -%}
            <div class="forge-editorial-hero__heading-line">{{ part }}{%- unless forloop.last -%}.{%- endunless -%}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.subheading != blank -%}
        <div class="forge-editorial-hero__subheading">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="forge-editorial-hero__cta">
          <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="forge-editorial-hero__button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="forge-editorial-hero__accent"></div>
  </div>

  <div class="forge-editorial-hero__right">
    {%- if section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w"
        sizes="(max-width: 767px) 100vw, 50vw"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        class="forge-editorial-hero__image">
    {%- else -%}
      <div class="forge-editorial-hero__placeholder"></div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Editorial Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dressed. With Intent."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Merino. British. Uncompromising."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Collection →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Editorial Hero"
    }
  ]
}
{% endschema %}