<style>
  @import url('https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;700&display=swap');
  .frm-hero { --frm-white: #F8F6F2; --frm-black: #0F0F0F; --frm-concrete: #B8B0A8; --frm-mid: #6B6560; --frm-border: #E0DDD8; --frm-warm: #F2EDE8; background: var(--frm-white); padding: {{ section.settings.padding_top }}px 64px {{ section.settings.padding_bottom }}px; font-family: 'Rubik', sans-serif; min-height: 90vh; display: flex; align-items: center; border-bottom: 1px solid var(--frm-border); }
  .frm-hero__inner { max-width: 1100px; margin: 0 auto; width: 100%; }
  .frm-hero__eyebrow { display: block; font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: var(--frm-concrete); margin: 0 0 32px; font-weight: 400; }
  .frm-hero__heading { font-size: clamp(40px, 7vw, 100px); font-weight: 300; letter-spacing: -.03em; color: var(--frm-black); margin: 0 0 28px; line-height: 1.05; max-width: 800px; }
  .frm-hero__sub { font-size: 16px; line-height: 1.8; color: var(--frm-mid); max-width: 480px; margin: 0 0 48px; font-weight: 300; }
  .frm-hero__actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .frm-hero__btn { display: inline-block; padding: 16px 48px; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; text-decoration: none; transition: all 0.25s ease; }
  .frm-hero__btn--primary { background: var(--frm-black); color: var(--frm-white); }
  .frm-hero__btn--primary:hover { background: var(--frm-mid); }
  .frm-hero__btn--secondary { background: transparent; color: var(--frm-black); text-decoration: underline; text-underline-offset: 3px; padding: 16px 0; }
  .frm-hero__btn--secondary:hover { color: var(--frm-mid); }
  .frm-hero__divider { width: 100%; height: 1px; background: var(--frm-border); margin-top: 80px; }
  @media (max-width: 768px) { .frm-hero { padding: 80px 24px; min-height: auto; } }
  @media (prefers-reduced-motion: reduce) { .frm-hero__btn { transition: none; } }
</style>

<section class="frm-hero">
  <div class="frm-hero__inner">
    {%- if section.settings.eyebrow != blank -%}<span class="frm-hero__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h1 class="frm-hero__heading">{{ section.settings.heading | default: 'Objects built to last a lifetime.' }}</h1>
    {%- if section.settings.subheading != blank -%}<p class="frm-hero__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    <div class="frm-hero__actions">
      {%- if section.settings.btn_primary_label != blank -%}
        <a href="{{ section.settings.btn_primary_url | default: '/collections/all' }}" class="frm-hero__btn frm-hero__btn--primary">{{ section.settings.btn_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.btn_secondary_label != blank -%}
        <a href="{{ section.settings.btn_secondary_url | default: '/pages/our-process' }}" class="frm-hero__btn frm-hero__btn--secondary">{{ section.settings.btn_secondary_label }}</a>
      {%- endif -%}
    </div>
    <div class="frm-hero__divider"></div>
  </div>
</section>

{% schema %}
{
  "name": "FORMA Hero",
  "tag": "section",
  "class": "frm-section-hero",
  "settings": [
    { "type": "text",     "id": "eyebrow",             "label": "Eyebrow",         "default": "Architectural Furniture" },
    { "type": "text",     "id": "heading",             "label": "Heading",         "default": "Objects built to last a lifetime." },
    { "type": "textarea", "id": "subheading",          "label": "Subheading",      "default": "Designed in London. Made in Europe. Built without compromise." },
    { "type": "text",     "id": "btn_primary_label",   "label": "Primary button",  "default": "Explore the Collection" },
    { "type": "url",      "id": "btn_primary_url",     "label": "Primary URL" },
    { "type": "text",     "id": "btn_secondary_label", "label": "Secondary button","default": "Our Process" },
    { "type": "url",      "id": "btn_secondary_url",   "label": "Secondary URL" },
    { "type": "range",    "id": "padding_top",         "label": "Padding top",     "min": 40, "max": 160, "step": 8, "default": 0 },
    { "type": "range",    "id": "padding_bottom",      "label": "Padding bottom",  "min": 40, "max": 160, "step": 8, "default": 0 }
  ],
  "presets": [{ "name": "FORMA Hero" }]
}
{% endschema %}
