<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;1,300;1,400;1,700&family=Inter:wght@300;400;500&display=swap');

  .vlr-hero {
    --vlr-black: #0A0A0A;
    --vlr-gold: #C9A84C;
    --vlr-ivory: #FAF6F0;
    --vlr-warm: #F2EDE4;
    --vlr-mid: #7A7269;
    --vlr-border: rgba(201,168,76,0.18);
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--vlr-black);
    overflow: hidden;
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', sans-serif;
  }
  .vlr-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201,168,76,0.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .vlr-hero__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    animation: vlr-fade-up 0.9s ease-out both;
  }
  @keyframes vlr-fade-up {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .vlr-hero__eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--vlr-gold);
    margin: 0 0 28px;
    font-weight: 400;
    animation: vlr-fade-up 0.9s 0.1s ease-out both;
  }
  .vlr-hero__heading {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(56px, 10vw, 128px);
    line-height: 0.92;
    letter-spacing: -.02em;
    color: var(--vlr-ivory);
    margin: 0 0 32px;
    animation: vlr-fade-up 0.9s 0.2s ease-out both;
  }
  .vlr-hero__sub {
    font-size: 16px;
    line-height: 1.8;
    color: var(--vlr-mid);
    max-width: 480px;
    margin: 0 auto 48px;
    font-weight: 300;
    animation: vlr-fade-up 0.9s 0.3s ease-out both;
  }
  .vlr-hero__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    animation: vlr-fade-up 0.9s 0.4s ease-out both;
  }
  .vlr-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 44px;
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .vlr-hero__btn--primary {
    border: 1px solid var(--vlr-gold);
    color: var(--vlr-gold);
    background: transparent;
  }
  .vlr-hero__btn--primary:hover {
    background: var(--vlr-gold);
    color: var(--vlr-black);
  }
  .vlr-hero__btn--secondary {
    border: 1px solid rgba(250,246,240,0.2);
    color: rgba(250,246,240,0.7);
    background: transparent;
  }
  .vlr-hero__btn--secondary:hover {
    border-color: var(--vlr-ivory);
    color: var(--vlr-ivory);
  }
  .vlr-hero__scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(250,246,240,0.3);
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .vlr-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(201,168,76,0.5), transparent);
    animation: vlr-scroll-line 2s ease-in-out infinite;
  }
  @keyframes vlr-scroll-line {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 0.8; transform: scaleY(1.2); }
  }
  @media (max-width: 768px) {
    .vlr-hero {
      padding: 80px 24px 120px;
    }
    .vlr-hero__heading {
      font-size: clamp(48px, 14vw, 80px);
    }
    .vlr-hero__actions {
      flex-direction: column;
      align-items: center;
    }
    .vlr-hero__btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .vlr-hero__inner,
    .vlr-hero__eyebrow,
    .vlr-hero__heading,
    .vlr-hero__sub,
    .vlr-hero__actions {
      animation: none;
    }
    .vlr-hero__scroll-line { animation: none; }
  }
</style>

<section class="vlr-hero">
  <div class="vlr-hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="vlr-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="vlr-hero__heading">{{ section.settings.heading | default: 'VELOUR.' }}</h1>

    {%- if section.settings.subheading != blank -%}
      <p class="vlr-hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="vlr-hero__actions">
      {%- if section.settings.btn_1_label != blank -%}
        <a href="{{ section.settings.btn_1_url | default: '/collections/all' }}" class="vlr-hero__btn vlr-hero__btn--primary">
          {{ section.settings.btn_1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn_2_label != blank -%}
        <a href="{{ section.settings.btn_2_url | default: '/pages/our-story' }}" class="vlr-hero__btn vlr-hero__btn--secondary">
          {{ section.settings.btn_2_label }} &rarr;
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="vlr-hero__scroll" aria-hidden="true">
    <div class="vlr-hero__scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "VELOUR Hero",
  "tag": "section",
  "class": "vlr-section-hero",
  "settings": [
    { "type": "text",    "id": "eyebrow",     "label": "Eyebrow",    "default": "New Season 2026" },
    { "type": "text",    "id": "heading",     "label": "Heading",    "default": "VELOUR." },
    { "type": "textarea","id": "subheading",  "label": "Subheading", "default": "Luxury fashion, crafted slowly." },
    { "type": "text",    "id": "btn_1_label", "label": "Button 1 label", "default": "Shop the Edit" },
    { "type": "url",     "id": "btn_1_url",   "label": "Button 1 URL" },
    { "type": "text",    "id": "btn_2_label", "label": "Button 2 label", "default": "Our Story" },
    { "type": "url",     "id": "btn_2_url",   "label": "Button 2 URL" },
    { "type": "range",   "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 200, "step": 8, "default": 0 },
    { "type": "range",   "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 8, "default": 0 }
  ],
  "presets": [{ "name": "VELOUR Hero" }]
}
{% endschema %}
