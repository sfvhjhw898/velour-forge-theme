<style>
  .vlr-testi {
    --vlr-black: #0A0A0A;
    --vlr-gold: #C9A84C;
    --vlr-ivory: #FAF6F0;
    --vlr-mid: #7A7269;
    padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;
    background: var(--vlr-black);
    font-family: 'Inter', sans-serif;
  }
  .vlr-testi__inner { max-width: 1200px; margin: 0 auto; }
  .vlr-testi__header { margin-bottom: 64px; }
  .vlr-testi__eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--vlr-gold);
    margin: 0 0 16px;
  }
  .vlr-testi__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(28px, 4vw, 52px);
    color: var(--vlr-ivory);
    margin: 0;
    letter-spacing: -.02em;
  }
  .vlr-testi__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .vlr-testi__card {
    padding: 40px 32px;
    border-left: 2px solid rgba(201,168,76,0.25);
    transition: border-color 0.3s ease;
  }
  .vlr-testi__card:hover { border-color: var(--vlr-gold); }
  .vlr-testi__quote-mark {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 80px;
    line-height: 0.6;
    color: rgba(201,168,76,0.2);
    margin: 0 0 24px;
    user-select: none;
  }
  .vlr-testi__quote {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(250,246,240,0.85);
    margin: 0 0 28px;
    font-weight: 300;
  }
  .vlr-testi__name {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--vlr-ivory);
    margin: 0 0 4px;
    letter-spacing: .05em;
  }
  .vlr-testi__role {
    font-size: 12px;
    color: var(--vlr-gold);
    font-weight: 300;
  }
  @media (max-width: 1024px) {
    .vlr-testi__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .vlr-testi { padding: 64px 24px; }
    .vlr-testi__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="vlr-testi">
  <div class="vlr-testi__inner">
    <div class="vlr-testi__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="vlr-testi__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vlr-testi__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="vlr-testi__grid">
      {%- for block in section.blocks -%}
        <div class="vlr-testi__card" {{ block.shopify_attributes }}>
          <span class="vlr-testi__quote-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="vlr-testi__quote">{{ block.settings.quote }}</blockquote>
          <footer>
            <span class="vlr-testi__name">{{ block.settings.name }}</span>
            {%- if block.settings.role != blank -%}
              <span class="vlr-testi__role">{{ block.settings.role }}</span>
            {%- endif -%}
          </footer>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VELOUR Testimonials",
  "tag": "section",
  "class": "vlr-section-testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Clients" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What they say." },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 40, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 160, "step": 8, "default": 96 }
  ],
  "blocks": [{
    "type": "testimonial",
    "name": "Testimonial",
    "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "The quality is unlike anything on the high street." },
      { "type": "text",     "id": "name",  "label": "Name",  "default": "A. Whitmore" },
      { "type": "text",     "id": "role",  "label": "Role",  "default": "Verified Buyer · London" }
    ]
  }],
  "presets": [{
    "name": "VELOUR Testimonials",
    "blocks": [
      { "type": "testimonial", "settings": { "quote": "The quality is unlike anything on the high street. VELOUR pieces feel genuinely luxurious.", "name": "A. Whitmore", "role": "Verified Buyer · London" } },
      { "type": "testimonial", "settings": { "quote": "Arrived in beautiful packaging. The garment is perfectly cut. I'll be ordering again.", "name": "C. Dupont", "role": "Verified Buyer · Paris" } },
      { "type": "testimonial", "settings": { "quote": "I've worn this piece to three events and received compliments at every one.", "name": "P. Nakashima", "role": "Verified Buyer · Tokyo" } }
    ]
  }]
}
{% endschema %}
