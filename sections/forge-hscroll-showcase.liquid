<section class="forge-hscroll-container color-{{ section.settings.color_scheme }}" data-forge-hscroll>
  {%- if section.settings.heading != blank -%}
    <div style="padding: 6vw 6vw 2rem; position: absolute; top: 0; left: 0; z-index: 2;">
      <h2 data-forge-split="words" data-forge-split-anim="reveal">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="forge-hscroll-track" style="padding-top: 8rem;">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_slide' and block.settings.product != blank -%}
        {%- assign prod = block.settings.product -%}
        <div class="forge-hscroll-slide" {{ block.shopify_attributes }}>
          <a href="{{ prod.url }}" class="forge-hscroll-card" data-forge-tilt>
            <div class="forge-hscroll-card__img">
              {{- prod.featured_image
                | image_url: width: 600
                | image_tag:
                    loading: 'lazy',
                    alt: prod.featured_image.alt | escape,
                    width: 600,
                    height: 800 -}}
            </div>
            <div class="forge-hscroll-card__info">
              <span>{{ prod.title }}</span>
              <span>{{ prod.price | money }}</span>
            </div>
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks | where: 'type', '@app' | size > 0 -%}
    <div class="forge-app-blocks" id="forge-app-blocks-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div {{ block.shopify_attributes }}>
            {%- render block.type, block: block, section: section -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "FORGE H-Scroll",
  "tag": "section",
  "settings": [
    { "type": "text",         "id": "heading",      "label": "Heading" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-5" }
  ],
  "blocks": [
    {
      "type": "product_slide",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Product" }]
    },
    { "type": "@app" }
  ],
  "presets": [{ "name": "FORGE H-Scroll" }],
  "max_blocks": 12
}
{% endschema %}
