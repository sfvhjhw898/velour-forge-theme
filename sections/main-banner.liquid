<section class="velour-hero" style="display:grid;grid-template-columns:480px 1fr;min-height:100svh;overflow:hidden;">
  <div style="background:#1A1A1A;padding:80px 60px;display:flex;flex-direction:column;justify-content:center;">
    <span style="display:block;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#C4A882;margin-bottom:32px;">Est. MMXXIV</span>
    <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:96px;font-weight:300;color:#F5F0EB;line-height:0.95;letter-spacing:-0.01em;margin:0 0 24px;">VELOUR</h1>
    <hr style="border:none;border-top:1px solid #C4A882;width:100%;margin:0 0 24px;">
    <p style="font-family:'Cormorant Garamond',Georgia,serif;font-size:18px;font-style:italic;color:rgba(245,240,235,0.7);margin:0 0 48px;line-height:1.5;">{{ section.settings.subheading | default: "Dressed with Intent." }}</p>
    <a href="/collections/all" style="font-size:12px;letter-spacing:0.15em;text-transform:uppercase;color:#C4A882;text-decoration:none;border-bottom:1px solid rgba(196,168,130,0.4);padding-bottom:2px;">Explore Collection →</a>
  </div>
  <div style="position:relative;overflow:hidden;">
    {%- if section.settings.image -%}
      <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="VELOUR" loading="eager" style="width:100%;height:100%;object-fit:cover;object-position:center top;display:block;">
    {%- endif -%}
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.25));"></div>
  </div>
</section>

<style>
  @media (max-width:989px){
    .velour-hero{
      grid-template-columns:1fr;
    }
    .velour-hero>div:first-child{
      padding:60px 32px;
    }
  }
  .velour-hero .shopify-section{
    min-height:unset;
  }
</style>

{% schema %}
{
  "name": "VELOUR Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial hero image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Italic subtitle",
      "default": "Dressed with Intent."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hidden — wordmark is always VELOUR"
    }
  ],
  "presets": [
    {
      "name": "VELOUR Hero"
    }
  ]
}
{% endschema %}