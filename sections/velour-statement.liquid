<style>
  .vlr-statement {
    --vlr-black: #0A0A0A;
    --vlr-gold: #C9A84C;
    --vlr-ivory: #FAF6F0;
    --vlr-mid: #7A7269;
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
    background: {% if section.settings.color_scheme == 'dark' %}var(--vlr-black){% else %}var(--vlr-ivory){% endif %};
    font-family: 'Playfair Display', Georgia, serif;
    text-align: center;
  }
  .vlr-statement__inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .vlr-statement__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--vlr-gold);
    margin: 0 0 32px;
    font-weight: 400;
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s ease;
    transform: translateY(16px);
  }
  .vlr-statement__text {
    font-style: italic;
    font-weight: 300;
    font-size: clamp(32px, 5.5vw, 80px);
    line-height: 1.15;
    letter-spacing: -.02em;
    color: {% if section.settings.color_scheme == 'dark' %}var(--vlr-ivory){% else %}var(--vlr-black){% endif %};
    margin: 0 0 32px;
    opacity: 0;
    transition: opacity 1s 0.15s ease, transform 1s 0.15s ease;
    transform: translateY(20px);
  }
  .vlr-statement__body {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.8;
    font-weight: 300;
    color: var(--vlr-mid);
    max-width: 560px;
    margin: 0 auto 0;
    opacity: 0;
    transition: opacity 0.8s 0.3s ease, transform 0.8s 0.3s ease;
    transform: translateY(12px);
  }
  .vlr-statement.is-visible .vlr-statement__eyebrow,
  .vlr-statement.is-visible .vlr-statement__text,
  .vlr-statement.is-visible .vlr-statement__body {
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 768px) {
    .vlr-statement { padding: 64px 24px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .vlr-statement__eyebrow,
    .vlr-statement__text,
    .vlr-statement__body {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<section class="vlr-statement" id="vlr-statement-{{ section.id }}">
  <div class="vlr-statement__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="vlr-statement__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.statement != blank -%}
      <p class="vlr-statement__text">{{ section.settings.statement }}</p>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="vlr-statement__body">{{ section.settings.body }}</p>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  var el = document.getElementById('vlr-statement-{{ section.id }}');
  if (!el) return;
  if (window.IntersectionObserver) {
    new IntersectionObserver(function(entries, obs) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.2 }).observe(el);
  } else {
    el.classList.add('is-visible');
  }
})();
</script>

{% schema %}
{
  "name": "VELOUR Statement",
  "tag": "section",
  "class": "vlr-section-statement",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",          "default": "The Edit" },
    { "type": "textarea", "id": "statement",    "label": "Statement text",   "default": "Fashion made to outlast every trend." },
    { "type": "textarea", "id": "body",         "label": "Body (optional)" },
    { "type": "select",   "id": "color_scheme", "label": "Colour scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" }
      ],
      "default": "light"
    },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 40, "max": 200, "step": 8, "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 200, "step": 8, "default": 120 }
  ],
  "presets": [{ "name": "VELOUR Statement" }]
}
{% endschema %}
