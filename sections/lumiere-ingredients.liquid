<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400&family=Inter:wght@300;400&display=swap');
  .lmi-ing { --lmi-rose: #F5EDE8; --lmi-pink: #C4917C; --lmi-cream: #FAF7F4; --lmi-dark: #2A1F1A; --lmi-mid: #8C7B75; --lmi-border: #E8DDD8; --lmi-shadow: 0 4px 24px rgba(42,31,26,0.08); background: var(--lmi-rose); padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; font-family: 'Inter', sans-serif; }
  .lmi-ing__inner { max-width: 1100px; margin: 0 auto; }
  .lmi-ing__header { text-align: center; margin-bottom: 56px; }
  .lmi-ing__eyebrow { display: block; font-size: 11px; letter-spacing: .26em; text-transform: uppercase; color: var(--lmi-pink); margin: 0 0 16px; font-weight: 300; }
  .lmi-ing__heading { font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(28px, 4vw, 52px); font-weight: 400; color: var(--lmi-dark); margin: 0; }
  .lmi-ing__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .lmi-ing__card { background: white; border-radius: 12px; box-shadow: var(--lmi-shadow); padding: 40px 32px; }
  .lmi-ing__icon { width: 56px; height: 56px; margin-bottom: 24px; }
  .lmi-ing__name { font-family: 'Playfair Display', serif; font-style: italic; font-size: 22px; font-weight: 400; color: var(--lmi-dark); margin: 0 0 8px; }
  .lmi-ing__origin { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--lmi-pink); font-weight: 300; margin: 0 0 16px; }
  .lmi-ing__desc { font-size: 14px; line-height: 1.7; color: var(--lmi-mid); margin: 0 0 16px; font-weight: 300; }
  .lmi-ing__conc { display: inline-block; background: var(--lmi-rose); color: var(--lmi-pink); font-size: 11px; font-weight: 400; letter-spacing: .1em; padding: 5px 14px; border-radius: 100px; }
  @media (max-width: 900px) { .lmi-ing { padding: 64px 24px; } .lmi-ing__grid { grid-template-columns: 1fr; gap: 16px; } }
</style>

<section class="lmi-ing">
  <div class="lmi-ing__inner">
    <div class="lmi-ing__header">
      {%- if section.settings.eyebrow != blank -%}<span class="lmi-ing__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="lmi-ing__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="lmi-ing__grid">
      {%- for block in section.blocks -%}
        <div class="lmi-ing__card" {{ block.shopify_attributes }}>
          {%- assign icon = block.settings.icon | default: 'drop' -%}
          <div class="lmi-ing__icon" aria-hidden="true">
            {%- if icon == 'leaf' -%}
              <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><path d="M28 8c0 0-16 8-16 24 0 8.837 7.163 16 16 16s16-7.163 16-16C44 16 28 8 28 8z" stroke="#C4917C" stroke-width="1.5" fill="none"/><path d="M28 48V28" stroke="#C4917C" stroke-width="1.5"/></svg>
            {%- elsif icon == 'crystal' -%}
              <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><polygon points="28,8 44,20 44,36 28,48 12,36 12,20" stroke="#C4917C" stroke-width="1.5" fill="none"/><line x1="28" y1="8" x2="28" y2="48" stroke="#C4917C" stroke-width="1" stroke-dasharray="3,3"/></svg>
            {%- elsif icon == 'flower' -%}
              <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="8" stroke="#C4917C" stroke-width="1.5" fill="none"/><ellipse cx="28" cy="14" rx="5" ry="8" stroke="#C4917C" stroke-width="1.5" fill="none"/><ellipse cx="28" cy="42" rx="5" ry="8" stroke="#C4917C" stroke-width="1.5" fill="none"/><ellipse cx="14" cy="28" rx="8" ry="5" stroke="#C4917C" stroke-width="1.5" fill="none"/><ellipse cx="42" cy="28" rx="8" ry="5" stroke="#C4917C" stroke-width="1.5" fill="none"/></svg>
            {%- else -%}
              <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><path d="M28 12 C28 12, 20 22, 20 30 A8 8 0 0 0 36 30 C36 22, 28 12, 28 12z" stroke="#C4917C" stroke-width="1.5" fill="none"/></svg>
            {%- endif -%}
          </div>
          <h3 class="lmi-ing__name">{{ block.settings.name | default: 'Ingredient' }}</h3>
          {%- if block.settings.origin != blank -%}<p class="lmi-ing__origin">{{ block.settings.origin }}</p>{%- endif -%}
          {%- if block.settings.description != blank -%}<p class="lmi-ing__desc">{{ block.settings.description }}</p>{%- endif -%}
          {%- if block.settings.concentration != blank -%}<span class="lmi-ing__conc">{{ block.settings.concentration }}</span>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LUMIÈRE Ingredients",
  "tag": "section",
  "class": "lmi-section-ingredients",
  "settings": [
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "The Formula" },
    { "type": "text",  "id": "heading", "label": "Heading", "default": "Ingredients that work." },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 40, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 160, "step": 8, "default": 96 }
  ],
  "blocks": [{ "type": "ingredient", "name": "Ingredient", "settings": [
    { "type": "select", "id": "icon", "label": "Icon",
      "options": [
        { "value": "drop",   "label": "Drop" },
        { "value": "leaf",   "label": "Leaf" },
        { "value": "crystal","label": "Crystal" },
        { "value": "flower", "label": "Flower" }
      ], "default": "drop" },
    { "type": "text",     "id": "name",          "label": "Name",          "default": "Hyaluronic Acid" },
    { "type": "text",     "id": "origin",        "label": "Origin",        "default": "Bio-fermented" },
    { "type": "textarea", "id": "description",   "label": "Description" },
    { "type": "text",     "id": "concentration", "label": "Concentration", "default": "2%" }
  ]}],
  "presets": [{ "name": "LUMIÈRE Ingredients", "blocks": [
    { "type": "ingredient", "settings": { "icon": "drop",   "name": "Hyaluronic Acid", "origin": "Bio-fermented",       "description": "Draws and retains moisture at three depths of the skin.", "concentration": "2%" } },
    { "type": "ingredient", "settings": { "icon": "leaf",   "name": "Bakuchiol",       "origin": "Psoralea corylifolia", "description": "Plant-derived retinol alternative. All the results, none of the sensitivity.", "concentration": "1%" } },
    { "type": "ingredient", "settings": { "icon": "crystal","name": "Niacinamide",     "origin": "Vitamin B3",          "description": "Brightens, minimises pores, and strengthens the skin barrier.", "concentration": "10%" } }
  ]}]
}
{% endschema %}
