<section class="forge-values-strip color-{{ section.settings.color_scheme }}"
         style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="forge-values-strip__inner">
    {%- if section.settings.heading != blank -%}
      <h2 style="font-family:var(--forge-font-heading,serif);font-size:clamp(1.6rem,3vw,3rem);font-weight:700;letter-spacing:-.02em;margin-bottom:3rem" data-forge-anim="fade-up">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="forge-values-strip__grid" data-forge-anim="stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="forge-values-strip__value" {{ block.shopify_attributes }}>
            {%- if block.settings.number != blank -%}
              <span class="forge-values-strip__num"
                    data-forge-varfont="wght"
                    data-forge-varfont-from="100"
                    data-forge-varfont-to="900">{{ block.settings.number }}</span>
            {%- endif -%}
            <h3 class="forge-values-strip__val-title">{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}
              <p class="forge-values-strip__body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FORGE Values Strip",
  "tag": "section",
  "settings": [
    {"type": "text", "id": "heading", "label": "Section heading"},
    {"type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1"},
    {"type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 8, "default": 80, "unit": "px"},
    {"type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 8, "default": 80, "unit": "px"}
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {"type": "text", "id": "number", "label": "Number or icon (optional)", "default": "01"},
        {"type": "text", "id": "title", "label": "Title", "default": "Crafted to last"},
        {"type": "textarea", "id": "body", "label": "Body", "default": "Every piece made with the highest-quality materials, built for decades not seasons."}
      ]
    },
    {"type": "@app"}
  ],
  "presets": [
    {
      "name": "FORGE Values Strip",
      "blocks": [
        {"type": "value", "settings": {"number": "01", "title": "Crafted to last", "body": "Premium materials, built to endure."}},
        {"type": "value", "settings": {"number": "02", "title": "Sustainably sourced", "body": "Ethical supply chain, transparent practices."}},
        {"type": "value", "settings": {"number": "03", "title": "Free returns", "body": "30-day no-questions-asked returns."}}
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
