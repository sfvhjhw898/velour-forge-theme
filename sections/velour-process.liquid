<style>
  .vlr-proc {
    --vlr-black: #0A0A0A;
    --vlr-gold: #C9A84C;
    --vlr-ivory: #FAF6F0;
    --vlr-mid: #7A7269;
    --vlr-border: rgba(201,168,76,0.15);
    padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;
    background: var(--vlr-ivory);
    font-family: 'Inter', sans-serif;
  }
  .vlr-proc__inner { max-width: 900px; margin: 0 auto; }
  .vlr-proc__header { margin-bottom: 64px; }
  .vlr-proc__eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--vlr-gold);
    margin: 0 0 16px;
  }
  .vlr-proc__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(28px, 4vw, 52px);
    color: var(--vlr-black);
    margin: 0;
    letter-spacing: -.02em;
  }
  .vlr-proc__steps { display: flex; flex-direction: column; }
  .vlr-proc__step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    align-items: start;
    padding: 40px 0;
    border-bottom: 1px solid var(--vlr-border);
    transition: all 0.3s ease;
  }
  .vlr-proc__step:first-child { border-top: 1px solid var(--vlr-border); }
  .vlr-proc__num {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 64px;
    font-weight: 300;
    color: rgba(201,168,76,0.2);
    line-height: 1;
    text-align: right;
    transition: color 0.3s ease;
    user-select: none;
  }
  .vlr-proc__step:hover .vlr-proc__num { color: rgba(201,168,76,0.5); }
  .vlr-proc__content { padding-top: 8px; }
  .vlr-proc__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 400;
    font-size: 22px;
    color: var(--vlr-black);
    margin: 0 0 12px;
    transition: color 0.3s ease;
  }
  .vlr-proc__step:hover .vlr-proc__title { color: var(--vlr-gold); }
  .vlr-proc__body {
    font-size: 15px;
    line-height: 1.8;
    color: var(--vlr-mid);
    margin: 0;
    font-weight: 300;
  }
  @media (max-width: 768px) {
    .vlr-proc { padding: 64px 24px; }
    .vlr-proc__step { grid-template-columns: 56px 1fr; gap: 20px; }
    .vlr-proc__num { font-size: 48px; }
  }
</style>

<section class="vlr-proc">
  <div class="vlr-proc__inner">
    <div class="vlr-proc__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="vlr-proc__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vlr-proc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="vlr-proc__steps">
      {%- for block in section.blocks -%}
        <div class="vlr-proc__step" {{ block.shopify_attributes }}>
          <span class="vlr-proc__num" aria-hidden="true">
            {%- if block.settings.number_override != blank -%}
              {{ block.settings.number_override }}
            {%- else -%}
              {{ forloop.index }}
            {%- endif -%}
          </span>
          <div class="vlr-proc__content">
            <h3 class="vlr-proc__title">{{ block.settings.title | default: 'Step' }}</h3>
            {%- if block.settings.body != blank -%}
              <p class="vlr-proc__body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VELOUR Process",
  "tag": "section",
  "class": "vlr-section-process",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Process" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From our atelier to your wardrobe." },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 40, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 160, "step": 8, "default": 96 }
  ],
  "blocks": [{
    "type": "step",
    "name": "Step",
    "settings": [
      { "type": "text",     "id": "number_override", "label": "Number (optional override)" },
      { "type": "text",     "id": "title",           "label": "Step title", "default": "Select Your Piece" },
      { "type": "textarea", "id": "body",            "label": "Description" }
    ]
  }],
  "presets": [{
    "name": "VELOUR Process",
    "blocks": [
      { "type": "step", "settings": { "title": "Select Your Piece", "body": "Carefully curated — never mass-produced. Take your time." } },
      { "type": "step", "settings": { "title": "Crafted to Order", "body": "Hand-finished in our London studio. Every stitch deliberate." } },
      { "type": "step", "settings": { "title": "Yours, Forever", "body": "Lifetime repair guarantee. Clothes that last decades." } }
    ]
  }]
}
{% endschema %}
